# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Pyinstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so no need to check them into github
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nosexmlresults
gpg.txt
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.hypothesis/
.pytest_cache/
cover/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this can be personal development environment detail.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if lock is generated on windows, it might fail on linux/macos.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains exact versions, but can be ignored if needed.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains exact versions.
#pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/
active/

# Spyder project settings
.spyderproject
.spyproject

# VS Code settings
.vscode/

# IntelliJ settings
.idea/

# OS metadata
.DS_Store
Thumbs.db

# Model checkpoints / Binary artifacts
*.bst
vertex_ai/*.bst
model.bst

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
*.tfvars.json
.terraform.lock.hcl

# Local system configuration / credentials
*.json
!schemas/transaction_event.json
!generator/credentials.json
.gcloud/
